{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "link-ear",
  "version": "0.1.0",
  "identifier": "dev.link-ear.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../desktop/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "link-ear",
        "width": 1120,
        "height": 720,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
